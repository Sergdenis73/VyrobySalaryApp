<Window x:Class="VyrobySalaryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VyrobySalaryApp"
        mc:Ignorable="d"
        x:Name="InfoSalaryForm"
        Title="Облік виробів та формування зарплат"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Головне меню програми -->
        <Menu x:Name="MainMenu" Grid.Row="0">
            <MenuItem x:Name="FileMenuItem" Header="Файл">
                <MenuItem x:Name="LoadDataMenuItem" Header="Завантажити" Click="LoadDataMenuItem_Click"/>
                <MenuItem x:Name="SaveDataMenuItem" Header="Зберегти звіт"/>
            </MenuItem>

            <MenuItem x:Name="RecordsMenuItem" Header="Записи">
                <MenuItem x:Name="AddDataMenuItem" Header="Додати" Click="AddDataMenuItem_Click"/>
                <MenuItem x:Name="EditDataMenuItem" Header="Редагувати" Click="EditDataMenuItem_Click"/>
                <MenuItem x:Name="DeleteDataMenuItem" Header="Видалити" Click="DeleteDataMenuItem_Click"/>
            </MenuItem>

            <MenuItem x:Name="SelectMenuItem" Header="Обробка">
                <MenuItem x:Name="SelectWorkshopMenuItem" Header="Відібрати за цехом"/>
                <MenuItem x:Name="AverageSalaryMenuItem" Header="Середня зарплата по цеху"/>
            </MenuItem>

            <MenuItem x:Name="AuthMenuItem" Header="Авторизація" Click="AuthMenuItem_Click"/>
        </Menu>

        <!-- Таблиця для відображення даних із БД -->
        <DataGrid x:Name="ProductsDataGrid"
                  Grid.Row="1"
                  Margin="10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  MouseDoubleClick="ProductsDataGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="Auto"/>
                <DataGridTextColumn Header="Прізвище складальника" Binding="{Binding surname}" Width="*"/>
                <DataGridTextColumn Header="Цех" Binding="{Binding workshop_number}" Width="Auto"/>
                <DataGridTextColumn Header="Вироби A" Binding="{Binding product_a}" Width="Auto"/>
                <DataGridTextColumn Header="Вироби Б" Binding="{Binding product_b}" Width="Auto"/>
                <DataGridTextColumn Header="Вироби C" Binding="{Binding product_c}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Блок введення/редагування запису -->
        <GroupBox x:Name="EditGroupBox"
                  Grid.Row="2"
                  Header="Введення / Редагування запису"
                  Margin="10"
                  Visibility="Collapsed">

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Прізвище:" VerticalAlignment="Center"/>
                <TextBox x:Name="SurnameTextBox" Grid.Column="1" Margin="5"/>

                <Label Grid.Column="2" Content="Цех:" VerticalAlignment="Center"/>
                <TextBox x:Name="WorkshopTextBox" Grid.Column="3" Margin="5"/>

                <Label Grid.Column="4" Content="A:" VerticalAlignment="Center"/>
                <TextBox x:Name="ProductATextBox" Grid.Column="5" Margin="5"/>

                <Label Grid.Column="6" Content="Б:" VerticalAlignment="Center"/>
                <TextBox x:Name="ProductBTextBox" Grid.Column="7" Margin="5"/>

                <Label Grid.Column="8" Content="C:" VerticalAlignment="Center"/>
                <TextBox x:Name="ProductCTextBox" Grid.Column="9" Margin="5"/>

                <Button x:Name="SaveEditButton"
                        Grid.Column="10"
                        Content="Зберегти"
                        Width="90"
                        Margin="10,5,5,5"
                        Click="SaveEditButton_Click"/>

                <Button x:Name="SaveNewButton"
                        Grid.Column="10"
                        Content="Додати"
                        Width="90"
                        Margin="10,5,5,5"
                        Visibility="Collapsed"
                        Click="SaveNewButton_Click"/>
            </Grid>
        </GroupBox>

        <!-- Нижній текстовий рядок стану -->
        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Margin="10"
                   Text="Користувач: Керівник. Режим перегляду."
                   FontSize="14"/>
    </Grid>
</Window>